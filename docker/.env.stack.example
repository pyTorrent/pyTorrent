# Note: Shared full-stack Docker variables.
# Local image names. The localhost/ prefix avoids Podman short-name registry lookup.
PYTORRENT_IMAGE=localhost/pytorrent:local
RTORRENT_IMAGE=localhost/pytorrent-rtorrent:local

# Private container network.
# The fixed rTorrent IP is also written to pyTorrent /etc/hosts, so Podman works even when aardvark-dns is missing.
PYTORRENT_NETWORK_SUBNET=10.89.90.0/24
RTORRENT_IPV4=10.89.90.10

PYTORRENT_BASE_IMAGE=python:3.14-alpine
PYTORRENT_HTTP_PORT=8090
PYTORRENT_SECRET_KEY=change-this-secret
PYTORRENT_HOST=0.0.0.0
PYTORRENT_PORT=8090
PYTORRENT_DB_PATH=/data/pytorrent.sqlite3
PYTORRENT_LOG_DIR=/data/logs
PYTORRENT_GEOIP_DB=/data/GeoLite2-City.mmdb
PYTORRENT_USE_OFFLINE_LIBS=true
PYTORRENT_LOG_ENABLE=true
PYTORRENT_AUTH_ENABLE=false
PYTORRENT_AUTH_PROVIDER=local
PYTORRENT_PROXY_FIX_ENABLE=false
PYTORRENT_SESSION_COOKIE_SECURE=false

# pyTorrent profile created at startup.
PYTORRENT_CONFIGURE_PROFILE=true
PYTORRENT_BASE_URL=http://127.0.0.1:8090
PYTORRENT_RTORRENT_PROFILE_NAME=Local rTorrent
PYTORRENT_RTORRENT_SCGI_URL=scgi://rtorrent:5000
PYTORRENT_RTORRENT_TIMEOUT=10
PYTORRENT_API_WAIT_SECONDS=90
PYTORRENT_API_TOKEN=

# rTorrent image base. Only distribution packages are used; no source compilation.
# Default: Debian package. 
# Alternative: alpine:3.24.
RTORRENT_BASE_IMAGE=debian:13-slim
RTORRENT_TERM=xterm

# rTorrent runtime configuration.
RTORRENT_SCGI_HOST=0.0.0.0
RTORRENT_SCGI_PORT=5000
RTORRENT_TORRENT_PORT=51300
RTORRENT_DHT_PORT=6881
RTORRENT_MIN_PEERS=40
RTORRENT_MAX_PEERS=200
RTORRENT_MAX_UPLOADS=50
RTORRENT_DOWNLOAD_RATE=0
RTORRENT_UPLOAD_RATE=0
RTORRENT_DHT=auto
RTORRENT_PEER_EXCHANGE=yes
RTORRENT_FORCE_CONFIG=false
RTORRENT_EXTRA_CONFIG=

# Host paths for torrent data.
RTORRENT_DOWNLOADS_PATH=./rtorrent-data/downloads
RTORRENT_WATCH_PATH=./rtorrent-data/watch
