# Note: pyTorrent-only Docker variables.
# Local image name. The localhost/ prefix avoids Podman short-name registry lookup.
PYTORRENT_IMAGE=local/pytorrent:local

PYTORRENT_BASE_IMAGE=python:3.14-alpine
PYTORRENT_HTTP_PORT=8090

PYTORRENT_SECRET_KEY=change-this-secret
PYTORRENT_HOST=0.0.0.0
PYTORRENT_PORT=8090
PYTORRENT_DB_PATH=/data/pytorrent.sqlite3
PYTORRENT_LOG_DIR=/data/logs
PYTORRENT_GEOIP_DB=/data/GeoLite2-City.mmdb
PYTORRENT_USE_OFFLINE_LIBS=true
PYTORRENT_LOG_ENABLE=true

# Existing rTorrent endpoint visible from the container.
PYTORRENT_CONFIGURE_PROFILE=true
PYTORRENT_BASE_URL=http://127.0.0.1:8090
PYTORRENT_RTORRENT_PROFILE_NAME=Existing rTorrent
PYTORRENT_RTORRENT_SCGI_URL=scgi://0.0.0.0:5000
PYTORRENT_RTORRENT_TIMEOUT=10
PYTORRENT_API_WAIT_SECONDS=90
PYTORRENT_API_TOKEN=

# Authentication is optional. Enable local auth only after setting a real secret and password.
PYTORRENT_AUTH_ENABLE=false
PYTORRENT_AUTH_PROVIDER=local
PYTORRENT_AUTH_PROXY_AUTO_CREATE=false
PYTORRENT_PROXY_FIX_ENABLE=false
PYTORRENT_SESSION_COOKIE_SECURE=false
